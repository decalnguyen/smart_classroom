# Copy to .env and adjust. docker-compose reads these (with safe defaults).

# --- Postgres ---
POSTGRES_USER=nhattoan
POSTGRES_PASSWORD=test123
POSTGRES_DB=sensordata

# --- Auth (JWT) ---
# REQUIRED. Generate a strong random secret (>= 32 bytes), e.g.:
#   openssl rand -base64 48
# Never commit the real value — keep it in .env (git-ignored) or a secret manager.
# In production (GIN_MODE=release / APP_ENV=production) the app refuses to start
# if this is unset, too short, or left at the insecure default.
JWT_SECRET=
JWT_ISSUER=smart-classroom
JWT_TTL_HOURS=24

# --- Device auth (ESP32 / Jetson camera) ---
# Shared fleet master key (X-Device-Key). Generate: openssl rand -hex 32
# Empty = master key disabled (only per-device tokens in device_credentials work).
# In production the insecure default 'dev-device-key' is refused.
DEVICE_API_KEY=
# Anti-replay for device events: reject scans/heartbeats whose ts is outside the
# window, and dedup by event_id. Set DEVICE_REPLAY_PROTECT=off to disable.
DEVICE_REPLAY_PROTECT=on
DEVICE_EVENT_MAX_SKEW_SECONDS=300

# --- Frontend origin allowed by CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Safety thresholds (alarm) ---
# Optional MANUAL override. Left unset, thresholds are data-driven (auto-calibrated
# μ+Kσ from collected readings — see internal/handlers/threshold_calibration.go).
SMOKE_THRESHOLD=
TEMP_THRESHOLD=

# --- Sensor simulator ---
ROOM_ID=A101
SIM_INTERVAL=5
SIM_SPIKE_EVERY=12
