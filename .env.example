# Copy to .env and adjust. docker-compose reads these (with safe defaults).

# --- Postgres ---
POSTGRES_USER=nhattoan
POSTGRES_PASSWORD=test123
POSTGRES_DB=sensordata

# --- Auth ---
# IMPORTANT: set a long random value in production.
JWT_SECRET=dev_insecure_secret_change_me

# --- Frontend origin allowed by CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Safety thresholds (alarm) ---
SMOKE_THRESHOLD=300
TEMP_THRESHOLD=50

# --- Sensor simulator ---
ROOM_ID=A101
SIM_INTERVAL=5
SIM_SPIKE_EVERY=12
