# Copy to .env (or export) on the Jetson. Values shown are examples.

# --- Backend integration ---
BACKEND_URL=http://192.168.1.10:8091     # HTTP API server (host:8091)
DEVICE_API_KEY=change-me-in-prod         # must match backend DEVICE_API_KEY / DeviceCredential token
CLASSROOM_ID=1                           # which classroom this camera covers
DEVICE_ID=cam-1                          # registered camera device id

# --- Camera ---
CAMERA_SRC=0                             # 0 = first CSI/USB cam; or an RTSP url
DET_SIZE=640                             # SCRFD detection input size
FRAME_STRIDE=5                           # run detection every Nth frame (Nano throughput)
MIN_FACE=60                              # ignore faces smaller than N px
COOLDOWN_SEC=30                          # don't re-report the same person within N s

# --- Matching mode ---
EDGE_MATCH=false                         # false = server matches (pgvector); true = match on edge (FAISS)
GALLERY_SYNC_SEC=300                     # how often to refresh the local gallery (EDGE_MATCH=true)
FACE_KNN=5                               # kNN neighbours for the weighted vote (matches training)
FACE_T_HIGH=0.60                         # accept threshold (cosine) — matches trained model
FACE_T_LOW=0.45                          # below = unknown; between = review queue (server-side)

# --- onnxruntime execution providers (TensorRT first, fall back to CUDA/CPU) ---
ORT_PROVIDERS=TensorrtExecutionProvider,CUDAExecutionProvider,CPUExecutionProvider
ORT_TENSORRT_ENGINE_CACHE_ENABLE=1
ORT_TENSORRT_CACHE_PATH=/home/jetson/trt_engines
