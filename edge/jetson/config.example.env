# Copy to .env (chmod 600) on the Jetson.  Edit before first run.

# --- Backend ---
BACKEND_URL=http://192.168.2.16:8091     # HTTP API server  (LAN — no public internet needed)
DEVICE_API_KEY=change-me-in-prod         # per-device token from device_credentials table
CLASSROOM_ID=1                           # which classroom this Jetson covers
DEVICE_ID=cam-1                          # registered device_id

# --- Local data files (relative to WorkingDirectory in the systemd unit) ---
GALLERY_FILE=gallery.json                # face embeddings per student
SCHEDULE_FILE=schedule.json              # timetable for this classroom

# --- Camera ---
CAMERA_SRC=0                             # 0 = first CSI/USB cam; or RTSP url; or video file path
DET_SIZE=640                             # SCRFD detection input size (pixels)
FRAME_STRIDE=5                           # run detection every Nth frame (Nano throughput)
MIN_FACE=60                              # ignore faces smaller than N px (noise guard)
COOLDOWN_SEC=30                          # don't re-report same student within N seconds

# --- Matching thresholds (same values as training notebook) ---
FACE_KNN=5
FACE_T_HIGH=0.60                         # cosine >= T_HIGH -> accept
FACE_T_LOW=0.45                          # cosine < T_LOW  -> unknown (ignored)

# --- onnxruntime execution providers ---
ORT_PROVIDERS=TensorrtExecutionProvider,CUDAExecutionProvider,CPUExecutionProvider
ORT_TENSORRT_ENGINE_CACHE_ENABLE=1
ORT_TENSORRT_CACHE_PATH=/home/jetson/trt_engines
